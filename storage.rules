rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function isOwnerOrAdmin(uid) {
      return isOwner(uid) || isAdmin();
    }

    match /users/{uid}/{allPaths=**} {
      allow read, write: if isOwnerOrAdmin(uid);
    }

    // Общие видео/материалы тренировок: читать можно авторизованным, менять только admin.
    match /workout-videos/{allPaths=**} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /exercise-videos/{allPaths=**} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /admin/{allPaths=**} {
      allow read, write: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
